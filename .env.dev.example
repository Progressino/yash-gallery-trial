# ──────────────────────────────────────────────────────────────
# Developer Local Environment — Production Module
# ──────────────────────────────────────────────────────────────
# Copy this file to .env before running docker compose up.
# These are development-only credentials — do NOT use production values.
#
#   cp .env.dev.example .env
# ──────────────────────────────────────────────────────────────

# Login credentials for the local app (devuser / DevProd2026!)
# Change the password after first login by updating AUTH_PASSWORD_HASH.
# Generate a new hash: python3 -c "import bcrypt; print(bcrypt.hashpw(b'YourNewPassword'.encode(), bcrypt.gensalt()).decode())"
AUTH_USERNAME=devuser
AUTH_PASSWORD_HASH=$2b$12$IjFTkK74B2XZkTd.P4K7seEaCbpjRiyoyen19R7ujRsBea45i7m8y

# JWT signing secret — keep any random string here for local dev
JWT_SECRET=dev-jwt-secret-local-only-change-if-needed

# GitHub cache — not required for local development
GITHUB_TOKEN=
GITHUB_REPO=

# Marketplace encryption key — required to start the app (use this dev key locally)
MARKETPLACE_ENCRYPTION_KEY=sDSww9Wy12j1uxUyZxlPqh-hFtSjOzIO0nwXi7VS4PQ=

# Finance module PIN — set any 4-digit number for local dev
FINANCE_PIN=0000

# Optional: allow an extra CORS origin if testing from a different port
# EXTRA_CORS_ORIGIN=http://localhost:3001
