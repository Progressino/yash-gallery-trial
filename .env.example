# ── PostgreSQL — durable forecast / upload session (recommended in production) ─
# docker-compose.prod.yml sets FORECAST_SESSION_DATABASE_URL automatically from this password.
# On the VPS, create /root/app-data/postgres once (Docker will populate the data dir).
FORECAST_PG_PASSWORD=change_me_strong_password
# Optional override (local dev / custom URL):
# FORECAST_SESSION_DATABASE_URL=postgresql://forecast:forecast@127.0.0.1:5433/forecast
# (Alias: DATABASE_URL is also accepted if FORECAST_SESSION_DATABASE_URL is unset.)

# Tier-3 SQLite: max parquet blobs kept per platform (Tier-1 + dailies). Default 200.
# DAILY_UPLOADS_MAX_PER_PLATFORM=200

# ── GitHub Releases cache ─────────────────────────────────────
# Used by the "Save / Load Cache" feature in the app.
# Create a fine-grained token with read+write access to releases on the repo.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=owner/repo-name

# ── Finance module 2FA PIN ────────────────────────────────────
# Required to access the Finance page. Leave unset to disable the lock.
FINANCE_PIN=your_secure_pin_here

# ── Marketplace API connections ───────────────────────────────
# Encryption key for storing marketplace API credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MARKETPLACE_ENCRYPTION_KEY=

# ── (Optional) Override allowed CORS origins ──────────────────
# Defaults are localhost:5173 and https://app.yashgallery.in
# EXTRA_CORS_ORIGIN=https://your-domain.com
