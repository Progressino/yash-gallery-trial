# ── PostgreSQL — durable forecast / upload session (recommended in production) ─
# docker-compose.prod.yml sets FORECAST_SESSION_DATABASE_URL automatically from this password.
# On the VPS, create /root/app-data/postgres once (Docker will populate the data dir).
FORECAST_PG_PASSWORD=change_me_strong_password
# Optional override (local dev / custom URL):
# FORECAST_SESSION_DATABASE_URL=postgresql://forecast:forecast@127.0.0.1:5433/forecast
# (Alias: DATABASE_URL is also accepted if FORECAST_SESSION_DATABASE_URL is unset.)

# Tier-3 SQLite: max parquet blobs kept per platform (Tier-1 + dailies). Default 200.
# DAILY_UPLOADS_MAX_PER_PLATFORM=200
# Months of Tier-3 history merged into session on full restore (default 12).
# AUTO_RESTORE_MONTHS=12
# Skip GitHub warm-cache Phase 2 when disk cache is fresh (saves RAM/CPU; default on).
# WARM_CACHE_SKIP_PHASE2_WHEN_DISK_FRESH=1
# Evict idle browser sessions from RAM every N seconds (default 1800).
# SESSION_EVICT_INTERVAL_SEC=1800
# Disable multi-GB PostgreSQL session ZIPs if the VPS disk fills (warm cache holds data).
# SESSION_PG_PERSIST=0
# SESSION_PG_MAX_BUNDLE_MB=80
# Shared operational snapshot + Tier-3 in PostgreSQL (recommended; uses same DB URL).
# FORECAST_OPS_PG=1
# DAILY_SALES_BACKEND=postgres
# SHARED_SNAPSHOT_MAX_MB=512
# Indexed inventory + sales tables (replaces parquet blobs when enabled).
# FORECAST_OPS_NORMALIZED=1
#
# PostgreSQL query analytics (pg_stat_statements) — enabled in docker-compose*.yml.
# After deploy: bash scripts/pg_slow_queries.sh
# One-time on existing VPS: bash scripts/pg_enable_stat_statements.sh
#
# Endpoint timing logs (logger: perf): PERF_TIMING=1  PERF_TIMING_MIN_SEC=0
#
# PO calculate stage breakdown (logger: perf.po): PERF_PO_STAGES=1
#
# Slow DB query logs (logger: db.perf; psycopg + sqlite, not SQLAlchemy):
# DB_SLOW_QUERY_LOG=1  DB_SLOW_QUERY_SEC=0.5
# Weekly maintenance (scripts/weekly_vps_maintenance.sh — Sunday 23:00 IST via GitHub Actions)
# WEEKLY_MAINTENANCE_KEEP_SESSIONS=15
# WEEKLY_MAINTENANCE_RUNNER_DIAG_DAYS=7

# ── GitHub Releases cache ─────────────────────────────────────
# Used by the "Save / Load Cache" feature in the app.
# Create a fine-grained token with read+write access to releases on the repo.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=owner/repo-name

# Local dev: writable warm-cache dir (default /data/warm_cache is Docker-only).
# WARM_CACHE_DIR=./.local-data/warm_cache

# ── Login: India mobile OTP (new devices) ─────────────────────
# Super Admin account (created/updated in users.db on startup)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PHONE=919876543210
# Require OTP when signing in from an untrusted browser (default on)
OTP_REQUIRED=1
# Super Admin only: skip OTP on all devices (password only). Other users still get OTP on new browsers.
# SUPER_ADMIN_OTP_BYPASS=1
# Dev only: log OTP to server console instead of SMS
# SMS_OTP_DEV=1
# MSG91 (India SMS) — https://msg91.com
# MSG91_AUTH_KEY=
# MSG91_SENDER_ID=PROGIN
# MSG91_TEMPLATE_ID=
DEVICE_TRUST_DAYS=90
OTP_TTL_MINUTES=10

# Only these usernames may delete uploads (clear platform, Tier-3 files, reset-all).
# Comma-separated; defaults to SUPER_ADMIN_USERNAME + AUTH_USERNAME when unset.
# UPLOAD_DELETE_ALLOWED_USERS=admin,your_username

# Legacy env login (also used to bootstrap Super Admin password hash)
# AUTH_USERNAME=admin
# AUTH_PASSWORD_HASH=$2b$12$...
JWT_SECRET=change-me-set-jwt-secret-in-env

# ── Finance module 2FA PIN ────────────────────────────────────
# Required to access the Finance page. Leave unset to disable the lock.
FINANCE_PIN=your_secure_pin_here

# ── Marketplace API connections ───────────────────────────────
# Encryption key for storing marketplace API credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MARKETPLACE_ENCRYPTION_KEY=

# ── (Optional) Override allowed CORS origins ──────────────────
# Defaults are localhost:5173 and https://app.yashgallery.in
# EXTRA_CORS_ORIGIN=https://your-domain.com
